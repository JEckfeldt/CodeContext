# =============================================================================
# CodeContext — Root .gitignore
# Monorepo: Next.js frontend, FastAPI backend, PostgreSQL/pgvector, Docker, AI
# =============================================================================

# -----------------------------------------------------------------------------
# Frontend (Next.js + TypeScript)
# -----------------------------------------------------------------------------

# Dependencies
node_modules/
.pnp
.pnp.js
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

# Next.js
.next/
out/
dist/
build/

# Production / static export artifacts
*.tsbuildinfo

# TypeScript
.tscache/
tsconfig.tsbuildinfo

# Frontend tooling caches
.eslintcache
.stylelintcache
.parcel-cache/
.turbo/
.vercel/

# Frontend test / coverage output
coverage/
.nyc_output/
playwright-report/
test-results/

# -----------------------------------------------------------------------------
# Backend (FastAPI + Python)
# -----------------------------------------------------------------------------

# Virtual environments
.venv/
venv/
env/
ENV/
.python-version.local

# Byte-compiled / optimized / compiled Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyd
*.pyo

# Distribution / packaging
*.egg
*.egg-info/
.eggs/
pip-wheel-metadata/
build/
dist/
*.manifest
*.spec
wheels/
share/python-wheels/

# Testing
.pytest_cache/
.tox/
.nox/
.hypothesis/
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover
*.py,cover
nosetests.xml
.cache/

# Type checkers / linters
.mypy_cache/
.dmypy.json
dmypy.json
.pytype/
.ruff_cache/

# Jupyter
.ipynb_checkpoints/

# pyenv / pipenv / poetry local state
.pipenv
Pipfile.lock.local

