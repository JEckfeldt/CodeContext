ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~
.fuse_hidden*
.directory
.Trash-*

# -----------------------------------------------------------------------------
# Docker and local infrastructure
# -----------------------------------------------------------------------------

# Local Docker volumes and bind-mount data
docker-data/
.docker-data/
volumes/
.docker/volumes/

# Generated PostgreSQL / pgvector data (local dev only)
postgres-data/
pgdata/
*.sql.backup
*.dump
*.sql.gz

# Docker override files with local-only settings
docker-compose.override.yml
docker-compose.*.local.yml

# -----------------------------------------------------------------------------
# AI, indexing, and generated data (CodeContext-specific)
# -----------------------------------------------------------------------------

# Uploaded / cloned repositories for indexing
data/uploads/
data/repositories/
data/repos/
uploads/
repositories/

# Generated embeddings and vector artifacts
data/embeddings/
data/vectors/
data/index/
embeddings/
vectors/
*.embedding
*.embeddings
*.faiss
*.hnsw

# Local vector database snapshots and exports
data/pgvector/
data/db/
*.pgdump

# Cached LLM responses and prompt artifacts
data/cache/
data/llm-cache/
cache/llm/
*.llm-cache

# Pipeline and ingestion generated output
data/generated/
data/processed/
data/chunks/
generated/
.tmp/
tmp/
temp/

# Model downloads and local weights (if cached locally)
models/
*.bin
*.safetensors
*.onnx
*.gguf

# Large or binary artifacts from indexing runs
*.sqlite
*.sqlite3
*.db
!**/migrations/**/*.db

# Logs from ingestion, search, and AI services
logs/
*.log

# -----------------------------------------------------------------------------
# Miscellaneous
# -----------------------------------------------------------------------------

# Local-only config overrides
*.local
*.local.*

# Archives (often used for repo uploads during dev)
*.zip
*.tar
*.tar.gz
*.tgz
*.rar
*.7z

# Swap and backup files
*.swp
*.swo
*.bak
*.orig
