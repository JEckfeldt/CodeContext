# Application
APP_ENV=development

# PostgreSQL
POSTGRES_USER=codecontext
POSTGRES_PASSWORD=change-me
POSTGRES_DB=codecontext
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Backend
DATABASE_URL=postgresql+asyncpg://codecontext:change-me@db:5432/codecontext
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:3000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
FRONTEND_PORT=3000

# AI / LLM (optional until Phase 4)
OPENAI_API_KEY=

# Local data paths (used by ingestion and indexing)
DATA_DIR=./data
