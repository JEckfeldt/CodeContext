# Application
APP_ENV=development

# PostgreSQL
POSTGRES_USER=codecontext
POSTGRES_PASSWORD=change-me
POSTGRES_DB=codecontext
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Backend
DATABASE_URL=postgresql+asyncpg://codecontext:change-me@db:5432/codecontext
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:3000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
FRONTEND_PORT=3000
# Docker dev file watching (set in docker-compose for bind mounts on Windows/macOS)
# WATCHPACK_POLLING=true
# CHOKIDAR_USEPOLLING=true
# CHOKIDAR_INTERVAL=1000

# Shared OpenAI credentials (embeddings + LLM when enabled)
OPENAI_API_KEY=

# Embeddings (Phase 2C — disabled by default)
EMBEDDING_ENABLED=false
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_BATCH_SIZE=64

# LLM chat completions (Phase 4 — disabled by default)
LLM_ENABLED=false
LLM_MODEL=gpt-4o-mini
LLM_MAX_TOKENS=2048
LLM_TIMEOUT_SECONDS=120
# Optional: postgresql+asyncpg://... for `pytest -m integration`
# CODECONTEXT_INTEGRATION_DATABASE_URL=

# Auth (JWT)
JWT_SECRET_KEY=change-me-use-a-long-random-secret-in-production
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Local data paths (used by ingestion and indexing)
DATA_DIR=./data
